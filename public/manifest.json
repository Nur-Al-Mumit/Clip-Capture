{
  "manifest_version": 3,
  "name": "Pure Capture Pro - SaaS YouTube Clipper",
  "version": "6.0",
  "description": "Premium 100% independent YouTube clipping with Pro SaaS features.",
  "permissions": ["activeTab", "scripting", "downloads", "tabs"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/watch*"],
      "js": ["content.js"],
      "css": ["assets/content.css"]
    }
  ],
  "host_permissions": ["*://*.youtube.com/*"]
}
